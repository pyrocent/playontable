{
    "rewrites": [
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "header",
                    "key": "x-vercel-error",
                    "value": "NOT_FOUND"
                }
            ],
            "destination": "/templates/errors/404.html"
        },
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "header",
                    "key": "Status Code",
                    "value": "405 Method Not Allowed"
                }
            ],
            "destination": "/templates/errors/405.html"
        },
        {
            "source": "/",
            "destination": "/templates/index.html"
        }
    ]
}